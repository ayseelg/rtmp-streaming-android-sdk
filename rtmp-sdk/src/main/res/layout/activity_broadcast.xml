<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- Camera Preview -->
    <FrameLayout
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/controlsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Modern Live Status Badge -->
    <androidx.cardview.widget.CardView
        android:id="@+id/liveStatusCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/live_red"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">
            
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/gradient_live" />
            
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CANLI"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginStart="8dp"
                android:letterSpacing="0.1" />
                
        </LinearLayout>
        
    </androidx.cardview.widget.CardView>

    <!-- Viewer Count Badge -->
    <androidx.cardview.widget.CardView
        android:id="@+id/viewerCountCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/overlay"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <TextView
            android:id="@+id/tvViewerCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👁️ 0 izleyici"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />
            
    </androidx.cardview.widget.CardView>

    <!-- Modern Viewer List -->
    <androidx.cardview.widget.CardView
        android:id="@+id/viewerListCard"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/overlay"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/viewerCountCard"
        app:layout_constraintEnd_toEndOf="parent">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👥 İzleyenler"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="15sp"
                android:paddingBottom="12dp" />
            
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/overlay_light"
                android:layout_marginBottom="12dp" />
            
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="240dp"
                android:scrollbars="none">
                
                <TextView
                    android:id="@+id/tvViewerList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Henüz kimse katılmadı"
                    android:textColor="#E2E8F0"
                    android:textSize="13sp"
                    android:lineSpacingExtra="6dp" />
                    
            </ScrollView>
            
        </LinearLayout>
        
    </androidx.cardview.widget.CardView>

    <!-- Close Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnClose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="@color/white"
        android:layout_margin="16dp"
        app:fabSize="mini"
        app:backgroundTint="@color/overlay"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Modern Controls Container -->
    <androidx.cardview.widget.CardView
        android:id="@+id/controlsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="32dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/surface_dark"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📡 Yayın Başlat"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="YouTube, Facebook veya kendi RTMP sunucunuza bağlanın"
                android:textColor="@color/text_tertiary"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingBottom="20dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilStreamTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="✨ Yayın Başlığı"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etStreamTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:inputType="text"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilRtmpUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🌐 RTMP Sunucu URL"
                android:layout_marginTop="12dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary"
                app:helperText="Örnek: rtmp://192.168.1.100:1935/live"
                app:helperTextTextColor="@color/text_tertiary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRtmpUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:inputType="textUri"
                    android:maxLines="1"
                    android:text="rtmp://" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilStreamKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔑 Stream Key"
                android:layout_marginTop="12dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary"
                app:helperText="Örnek: test, stream, mykey"
                app:helperTextTextColor="@color/text_tertiary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etStreamKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:inputType="text"
                    android:maxLines="1"
                    android:text="test" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSwitchCamera"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="🔄 Kamera"
                    android:textSize="15sp"
                    android:layout_marginEnd="12dp"
                    app:backgroundTint="@color/surface_dark"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="2dp"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStartStop"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="▶️ Başlat"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="16dp" />

            </LinearLayout>

        </LinearLayout>
        
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
